# Required: secret key for signing session cookies
# Generate with: openssl rand -hex 32
SECRET_KEY=

# Optional: path to the SQLite database (default: ./data/partiu.db)
DB_PATH=./data/partiu.db

# Optional: disable background email sync (useful for dev/testing)
DISABLE_SCHEDULER=false

# Optional: set to false when testing over plain HTTP (e.g. mobile on local network)
SECURE_COOKIES=true

# Optional: AviationStack API key for aircraft type lookup (100 req/month free)
# Sign up at https://aviationstack.com → free plan → copy your Access Key
AVIATIONSTACK_API_KEY=

# Optional: LLM fallback for parsing emails from unknown airlines.
# Requires a running Ollama instance (see docker-compose.yml for the ollama service).
# Leave OLLAMA_URL empty to disable the LLM fallback entirely.
# OLLAMA_URL=http://ollama:11434
# OLLAMA_MODEL=qwen2.5:1.5b
